<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Livraria</title>
    <style>
        .caixa {
            background-color: rgb(125, 89, 140);
            /* width: 900px; */
            height: 90px;
            border-radius: 10px;
            display: flex;
            justify-content: space-around;
            align-items: center;


        }

        .caixinha {
            width: 350px;
            height: 50px;
            border-radius: 20px;
            background-color: rgb(229, 227, 227);
            display: flex;
            flex-direction: row;
            justify-content: center;
            margin: 6px;
            align-items: center;
            color: rgb(109, 109, 109);

        }

        .caixaprincipal {
            width: 400px;
            height: 300px;
            background-color: rgb(245 237 231);
            margin: 10px;
            border-radius: 20px;
            display: flex;
            gap: 5px;


        }

        .caixanova {
            display: flex;
            flex-direction: row;
            justify-content: space-around;
            margin-bottom: 10px;

        }

        .caixadeinformações {
            width: 400px;
            height: 200px;
            background-color: rgb(245 237 231);
            border-radius: 40px;
            display: flex;
            justify-content: center;
            flex-direction: column;
           
           

        }

        .caixadainformação {
           width: 100%;
            display: flex;
            justify-content: center;
            border: 200px;


        }

        .banner {
            width: 100%;
            height: 500px;
            display: flex;
            object-fit: contain;

        }

        .Imagemdoslivros {
            width: 200px;
            height: 290px;
            display: flex;
            justify-content: center;


        }

        .nomundodaluna {
            width: 200px;
            height: 280px;
            display: flex;
            justify-content: center;
        }

        .duda {
            width: 100%;
        }

        .escritas {
            font-size: 25px;
            gap: 5px;




        }

        .btn {
            width: 190px;
            height: 50px;
            border-radius: 5px;
            background-color: rgb(255, 255, 255);



        }

        footer {
            text-align: center;
            background-color: rgb(125, 89, 140);
            color: rgb(255, 255, 255);
        }

        input {
            height: 40px;
            width: 340px;

        }

        .pesquise {
            height: 40px;
            width: 340px;
            border-radius: 20px;
        }

        .caixadeemailetals {
            margin: 1px;
            display: flex;
            border-radius: 8px;
            margin-left: 25px;
            
        }
        .botao{
            border-radius: 20px;
            margin: 20px;
            width: 100px;
            margin-left:150px ;
            
           
        
        }
        .texto{
            color: rgb(0, 0, 0);
            text-align: center;
        }
        
    </style>

</head>

<body>
